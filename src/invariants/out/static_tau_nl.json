{
  "assertion_name": "authenticate_before_data_access_or_actions",
  "taxonomy_targets": [
    "Instruction/PlanAdherenceFailure",
    "IntentPlanMisalignment"
  ],
  "invariant_type": "TEMPORAL",
  "event_trigger": {
    "step_index": 1,
    "role_name": "*"
  },
  "check_hint": "Authentication via find_user_id_by_email or find_user_id_by_name_zip must occur before any order/profile data access (get_user_details/get_order_details) and any consequential write actions (cancel, modify, return, exchange). Verify that a prior authentication tool call exists and was followed by a tool response indicating a user_id before the current operation.",
  "check_type": "python_check",
  "python_check": {
    "function_name": "authenticate_before_data_access_or_actions",
    "args": [
      "trajectory",
      "current_step_index"
    ],
    "code_lines": [
      "import re, json",
      "",
      "def authenticate_before_data_access_or_actions(trajectory, current_step_index):",
      "    \"\"\"Return True iff invariant holds.",
      "    Ensures user authentication (find_user_id_by_email or find_user_id_by_name_zip) occurred before any data access (get_user_details/get_order_details) or write-action tools (cancel_pending_order, modify*, return_delivered_order_items, exchange_delivered_order_items).\"\"\"",
      "    print(\"authenticate_before_data_access_or_actions: start\")",
      "    try:",
      "        steps = trajectory['steps']",
      "        step = steps[current_step_index]",
      "        substeps = step.get('substeps', [])",
      "    except (KeyError, IndexError, TypeError) as e:",
      "        print(\"authenticate_before_data_access_or_actions: structural error\", e)",
      "        raise",
      "",
      "    # Helper: detect if assistant content has a tool call and get tool name",
      "    tool_name = None",
      "    args_dict = None",
      "    for ss in substeps:",
      "        if ss.get('role') == 'assistant':",
      "            content = ss.get('content', '')",
      "            name_match = re.search(r'\\\"name\\\"\\s*:\\s*\\\"([^\\\"]+)\\\"', content)",
      "            if name_match:",
      "                tool_name = name_match.group(1)",
      "                args_match = re.search(r'\\\"arguments\\\"\\s*:\\s*\\\"(.*?)\\\"', content, re.DOTALL)",
      "                if args_match:",
      "                    arg_str = args_match.group(1)",
      "                    try:",
      "                        args_dict = json.loads(arg_str)",
      "                    except Exception as e:",
      "                        print(\"authenticate_before_data_access_or_actions: args parse failed\", e)",
      "                        args_dict = None",
      "                break",
      "",
      "    print(\"authenticate_before_data_access_or_actions: current tool_name=\", tool_name, \"args_dict=\", args_dict)",
      "    if not tool_name:",
      "        # No tool call by assistant in this step; invariant does not apply",
      "        return True",
      "",
      "    protected_tools = {",
      "        'get_user_details',",
      "        'get_order_details',",
      "        'cancel_pending_order',",
      "        'modify_pending_order_address',",
      "        'modify_pending_order_items',",
      "        'modify_pending_order_payment',",
      "        'return_delivered_order_items',",
      "        'exchange_delivered_order_items'",
      "    }",
      "    if tool_name not in protected_tools:",
      "        return True",
      "",
      "    # Scan backwards to confirm authentication occurred and a user_id was obtained",
      "    authenticated = False",
      "    auth_tool_called = False",
      "    for i in range(current_step_index - 1, -1, -1):",
      "        prev_step = steps[i]",
      "        for pss in prev_step.get('substeps', []):",
      "            if pss.get('role') == 'assistant':",
      "                cont = pss.get('content', '')",
      "                if re.search(r'\\\"name\\\"\\s*:\\s*\\\"find_user_id_by_email\\\"', cont) or re.search(r'\\\"name\\\"\\s*:\\s*\\\"find_user_id_by_name_zip\\\"', cont):",
      "                    auth_tool_called = True",
      "            if pss.get('role') == 'tool':",
      "                tool_cont = pss.get('content', '').strip()",
      "                # Authentication tool typically returns a raw user_id string; accept alnum+underscore",
      "                if re.fullmatch(r'[A-Za-z0-9_]+', tool_cont):",
      "                    authenticated = True",
      "                    break",
      "                # Or user details JSON contains email; treat as authenticated context too",
      "                try:",
      "                    j = json.loads(tool_cont)",
      "                    if isinstance(j, dict) and (('email' in j) or ('user_id' in j)):",
      "                        authenticated = True",
      "                        break",
      "                except Exception:",
      "                    pass",
      "        if authenticated:",
      "            break",
      "",
      "    print(\"authenticate_before_data_access_or_actions: auth_tool_called=\", auth_tool_called, \"authenticated=\", authenticated)",
      "    if auth_tool_called and authenticated:",
      "        return True",
      "    # If attempting protected operation without prior authentication evidence → violation",
      "    return False"
    ]
  },
  "nl_check": {}
}