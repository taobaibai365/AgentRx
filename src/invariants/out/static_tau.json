    {
      "assertion_name": "user_confirmation_before_consequential_action",
      "taxonomy_targets": [
        "Instruction/PlanAdherenceFailure"
      ],
      "invariant_type": "TEMPORAL",
      "event_trigger": {
        "step_index": 1,
        "role_name": "assistant"
      },
      "check_hint": "Before any consequential database-updating action (cancel, modify, return, exchange), the assistant must obtain explicit user confirmation. This check triggers when the assistant calls any action tool and verifies that the immediately preceding user message contains confirmation tokens such as 'yes', 'confirm', 'proceed', or 'go ahead'.",
      "check_type": "python_check",
      "python_check": {
        "function_name": "user_confirmation_before_consequential_action",
        "args": [
          "trajectory",
          "current_step_index"
        ],
        "code_lines": [
          "def user_confirmation_before_consequential_action(trajectory, current_step_index):",
          "    \"\"Return True iff an action tool call is preceded by explicit user confirmation tokens in the latest prior user message.\"\"",
          "    print(\"user_confirmation_before_consequential_action invoked\")",
          "    import re",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    assistant_substeps = [s for s in step.get(\"substeps\", []) if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    action_tools = [",
          "        \"cancel_pending_order\",",
          "        \"exchange_delivered_order_items\",",
          "        \"modify_pending_order_address\",",
          "        \"modify_pending_order_items\",",
          "        \"modify_pending_order_payment\",",
          "        \"return_delivered_order_items\"",
          "    ]",
          "    is_action_call = any(re.search(r\"\\b\" + re.escape(t) + r\"\\b\", content) for t in action_tools)",
          "    print(\"Is action tool call:\", is_action_call)",
          "    if not is_action_call:",
          "        return True",
          "    # Find last user message prior to current step",
          "    last_user_msg = None",
          "    for i in range(current_step_index - 1, -1, -1):",
          "        prev = trajectory[\"steps\"][i]",
          "        for ss in prev.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"user\":",
          "                last_user_msg = ss.get(\"content\", \"\") or \"\"",
          "                break",
          "        if last_user_msg is not None:",
          "            break",
          "    print(\"Last user message:\", (last_user_msg[:200] + \"...\") if last_user_msg and len(last_user_msg) > 200 else last_user_msg)",
          "    if not last_user_msg:",
          "        print(\"Violation: No prior user message found to confirm action.\")",
          "        return False",
          "    msg = last_user_msg.lower()",
          "    confirmation_tokens = [\"yes\", \"confirm\", \"proceed\", \"go ahead\", \"approved\", \"approve\", \"do it\", \"continue\", \"ok\", \"okay\"]",
          "    confirmed = any(tok in msg for tok in confirmation_tokens)",
          "    print(\"Confirmed tokens present:\", confirmed)",
          "    if not confirmed:",
          "        print(\"Violation: Consequential action without explicit user confirmation.\")",
          "        return False",
          "    return True"
        ]
      },
      "nl_check": {}
    },
    {
      "assertion_name": "order_status_preconditions",
      "taxonomy_targets": [
        "Instruction/PlanAdherenceFailure",
        "MisinterpretationOfToolOutput"
      ],
      "invariant_type": "PROVENANCE",
      "event_trigger": {
        "step_index": 1,
        "role_name": "assistant"
      },
      "check_hint": "Cancel/modify actions require the order to be 'pending', while return/exchange actions require 'delivered'. This check triggers on action tool calls, extracts the order_id from the call, and verifies that a prior get_order_details tool result exists with the correct status.",
      "check_type": "python_check",
      "python_check": {
        "function_name": "order_status_preconditions",
        "args": [
          "trajectory",
          "current_step_index"
        ],
        "code_lines": [
          "def order_status_preconditions(trajectory, current_step_index):",
          "    \"\"Return True iff the order status in prior get_order_details output matches the required preconditions for the current action tool.\"\"",
          "    print(\"order_status_preconditions invoked\")",
          "    import re, json",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    assistant_substeps = [s for s in step.get(\"substeps\", []) if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    # Determine action type",
          "    actions_pending = [\"cancel_pending_order\", \"modify_pending_order_address\", \"modify_pending_order_items\", \"modify_pending_order_payment\"]",
          "    actions_delivered = [\"return_delivered_order_items\", \"exchange_delivered_order_items\"]",
          "    action_name = None",
          "    for a in actions_pending + actions_delivered:",
          "        if re.search(r\"\\b\" + re.escape(a) + r\"\\b\", content):",
          "            action_name = a",
          "            break",
          "    print(\"Detected action_name:\", action_name)",
          "    if not action_name:",
          "        return True",
          "    # Extract order_id from assistant content (escaped or unescaped)",
          "    order_id = None",
          "    patterns = [r\"order_id\\\\\\\"\\s*:\\s*\\\\\\\"([^\\\\\\\"]+)\", r\"order_id\\s*:\\s*\\\"([^\\\"]+)\\\"\", r\"(#\\w+\\d+)\"]",
          "    for pat in patterns:",
          "        m = re.search(pat, content)",
          "        if m:",
          "            order_id = m.group(1)",
          "            break",
          "    print(\"Extracted order_id:\", order_id)",
          "    if not order_id:",
          "        print(\"Violation: Unable to extract order_id from action call.\")",
          "        return False",
          "    # Find prior tool output for get_order_details with this order_id",
          "    prior_status = None",
          "    for i in range(0, current_step_index):",
          "        st = trajectory[\"steps\"][i]",
          "        for ss in st.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"tool\":",
          "                tc = ss.get(\"content\", \"\") or \"\"",
          "                # Attempt to parse JSON tool payloads",
          "                try:",
          "                    data = json.loads(tc)",
          "                    if isinstance(data, dict) and str(data.get(\"order_id\", \"\")) == order_id:",
          "                        prior_status = str(data.get(\"status\", \"\"))",
          "                        print(\"Found prior order status:\", prior_status)",
          "                except Exception:",
          "                    # non-JSON tool output, skip",
          "                    pass",
          "        if prior_status:",
          "            break",
          "    if not prior_status:",
          "        print(\"Violation: No prior get_order_details status found for order.\")",
          "        return False",
          "    if action_name in actions_pending and prior_status.lower() != \"pending\":",
          "        print(\"Violation: Pending action attempted on non-pending order.\")",
          "        return False",
          "    if action_name in actions_delivered and prior_status.lower() != \"delivered\":",
          "        print(\"Violation: Return/exchange action attempted on non-delivered order.\")",
          "        return False",
          "    return True"
        ]
      },
      "nl_check": {}
    },
    {
      "assertion_name": "refund_destination_compliance_for_returns",
      "taxonomy_targets": [
        "Instruction/PlanAdherenceFailure",
        "MisinterpretationOfToolOutput"
      ],
      "invariant_type": "PROVENANCE",
      "event_trigger": {
        "step_index": 1,
        "role_name": "assistant"
      },
      "check_hint": "For returns, refunds must go to the original payment method or an existing gift card. If the assistant specifies a refund payment_method_id in a return_delivered_order_items call, this check ensures it matches the original payment method from prior order_details or is a gift card present in the user's payment_methods.",
      "check_type": "python_check",
      "python_check": {
        "function_name": "refund_destination_compliance_for_returns",
        "args": [
          "trajectory",
          "current_step_index"
        ],
        "code_lines": [
          "def refund_destination_compliance_for_returns(trajectory, current_step_index):",
          "    \"\"Return True iff a specified refund payment method for returns is either the original payment method or an existing gift card.\"\"",
          "    print(\"refund_destination_compliance_for_returns invoked\")",
          "    import re, json",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    assistant_substeps = [s for s in step.get(\"substeps\", []) if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    if not re.search(r\"\\breturn_delivered_order_items\\b\", content):",
          "        return True",
          "    # Extract order_id and optionally payment_method_id",
          "    order_id = None",
          "    pay_id = None",
          "    oid_patterns = [r\"order_id\\\\\\\"\\s*:\\s*\\\\\\\"([^\\\\\\\"]+)\", r\"order_id\\s*:\\s*\\\"([^\\\"]+)\\\"\", r\"(#\\w+\\d+)\"]",
          "    for pat in oid_patterns:",
          "        m = re.search(pat, content)",
          "        if m:",
          "            order_id = m.group(1)",
          "            break",
          "    pm_patterns = [r\"payment_method_id\\\\\\\"\\s*:\\s*\\\\\\\"([^\\\\\\\"]+)\", r\"payment_method_id\\s*:\\s*\\\"([^\\\"]+)\\\"\"]",
          "    for pat in pm_patterns:",
          "        m = re.search(pat, content)",
          "        if m:",
          "            pay_id = m.group(1)",
          "            break",
          "    print(\"Extracted order_id:\", order_id, \"payment_method_id:\", pay_id)",
          "    if pay_id is None:",
          "        print(\"No payment_method_id specified in call; invariant not applicable.\")",
          "        return True",
          "    # Find original payment method id from prior order_details",
          "    original_pm = None",
          "    for i in range(0, current_step_index):",
          "        st = trajectory[\"steps\"][i]",
          "        for ss in st.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"tool\":",
          "                tc = ss.get(\"content\", \"\") or \"\"",
          "                try:",
          "                    data = json.loads(tc)",
          "                    if isinstance(data, dict) and order_id and str(data.get(\"order_id\", \"\")) == order_id:",
          "                        # find payment_history with transaction_type 'payment'",
          "                        ph = data.get(\"payment_history\")",
          "                        if isinstance(ph, list) and ph:",
          "                            for tx in ph:",
          "                                if isinstance(tx, dict) and str(tx.get(\"transaction_type\", \"\")).lower() == \"payment\":",
          "                                    original_pm = str(tx.get(\"payment_method_id\", \"\"))",
          "                                    print(\"Found original payment method:\", original_pm)",
          "                                    break",
          "                except Exception:",
          "                    pass",
          "            if original_pm:",
          "                break",
          "        if original_pm:",
          "            break",
          "    # Find whether pay_id is an existing gift card in user profile",
          "    is_gift_card = False",
          "    user_has_pay_id = False",
          "    for i in range(0, current_step_index):",
          "        st = trajectory[\"steps\"][i]",
          "        for ss in st.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"tool\":",
          "                tc = ss.get(\"content\", \"\") or \"\"",
          "                try:",
          "                    data = json.loads(tc)",
          "                    if isinstance(data, dict) and \"payment_methods\" in data:",
          "                        pm = data.get(\"payment_methods\")",
          "                        if isinstance(pm, dict) and pay_id in pm:",
          "                            user_has_pay_id = True",
          "                            src = str(pm[pay_id].get(\"source\", \"\")).lower()",
          "                            if \"gift\" in src:",
          "                                is_gift_card = True",
          "                            print(\"User has pay_id:\", user_has_pay_id, \"source:\", src)",
          "                except Exception:",
          "                    pass",
          "    # Evaluate compliance",
          "    if original_pm and pay_id == original_pm:",
          "        return True",
          "    if user_has_pay_id and is_gift_card:",
          "        return True",
          "    print(\"Violation: Refund destination is neither original payment method nor an existing gift card.\")",
          "    return False"
        ]
      },
      "nl_check": {}
    },
    {
      "assertion_name": "single_use_actions_only_once_per_order",
      "taxonomy_targets": [
        "Instruction/PlanAdherenceFailure"
      ],
      "invariant_type": "TEMPORAL",
      "event_trigger": {
        "step_index": 1,
        "role_name": "assistant"
      },
      "check_hint": "Exchange items and modify items tools are single-use per order. This check ensures that for exchange_delivered_order_items or modify_pending_order_items, the same function has not been invoked earlier in the trajectory for the same order_id.",
      "check_type": "python_check",
      "python_check": {
        "function_name": "single_use_actions_only_once_per_order",
        "args": [
          "trajectory",
          "current_step_index"
        ],
        "code_lines": [
          "def single_use_actions_only_once_per_order(trajectory, current_step_index):",
          "    \"\"Return True iff 'exchange_delivered_order_items' or 'modify_pending_order_items' has not been previously called for the same order_id.\"\"",
          "    print(\"single_use_actions_only_once_per_order invoked\")",
          "    import re",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    assistant_substeps = [s for s in step.get(\"substeps\", []) if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    target_funcs = [\"exchange_delivered_order_items\", \"modify_pending_order_items\"]",
          "    func = None",
          "    for f in target_funcs:",
          "        if re.search(r\"\\b\" + re.escape(f) + r\"\\b\", content):",
          "            func = f",
          "            break",
          "    print(\"Detected function:\", func)",
          "    if not func:",
          "        return True",
          "    # Extract order_id",
          "    order_id = None",
          "    patterns = [r\"order_id\\\\\\\"\\s*:\\s*\\\\\\\"([^\\\\\\\"]+)\", r\"order_id\\s*:\\s*\\\"([^\\\"]+)\\\"\", r\"(#\\w+\\d+)\"]",
          "    for pat in patterns:",
          "        m = re.search(pat, content)",
          "        if m:",
          "            order_id = m.group(1)",
          "            break",
          "    print(\"Extracted order_id:\", order_id)",
          "    if not order_id:",
          "        print(\"Violation: Unable to extract order_id for single-use check.\")",
          "        return False",
          "    # Scan prior assistant calls for same func & order_id",
          "    for i in range(0, current_step_index):",
          "        st = trajectory[\"steps\"][i]",
          "        for ss in st.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"assistant\":",
          "                c = ss.get(\"content\", \"\") or \"\"",
          "                if re.search(r\"\\b\" + re.escape(func) + r\"\\b\", c):",
          "                    # check same order id",
          "                    for pat in patterns:",
          "                        m2 = re.search(pat, c)",
          "                        if m2 and m2.group(1) == order_id:",
          "                            print(\"Violation: Single-use function re-invoked for same order at step\", i+1)",
          "                            return False",
          "    return True"
        ]
      },
      "nl_check": {}
    },
