{
  "invariants": [
    {
      "assertion_name": "authentication_before_order_actions",
      "taxonomy_targets": [
        "Instruction/PlanAdherenceFailure",
        "IntentPlanMisalignment"
      ],
      "invariant_type": "TEMPORAL",
      "event_trigger": {
        "step_index": 1,
        "role_name": "assistant"
      },
      "check_hint": "Before any order-related retrieval or consequential action, the user must be authenticated by locating the user_id via email or via name+zip. This check triggers when the assistant attempts get_order_details or any action tool and scans prior steps for find_user_id_by_email or find_user_id_by_name_zip calls. It also verifies that such authentication occurred earlier in the trajectory, not after the action.",
      "check_type": "python_check",
      "python_check": {
        "function_name": "authentication_before_order_actions",
        "args": [
          "trajectory",
          "current_step_index"
        ],
        "code_lines": [
          "def authentication_before_order_actions(trajectory, current_step_index):",
          "    \"\"Return True iff any order info/action tool call is preceded by user authentication via find_user_id_by_email or find_user_id_by_name_zip.\"\"",
          "    print(\"authentication_before_order_actions invoked\")",
          "    import re",
          "    # Safety: validate trajectory structure",
          "    if trajectory is None or not isinstance(trajectory, dict):",
          "        raise TypeError(\"trajectory must be a dict\")",
          "    if \"steps\" not in trajectory or not isinstance(trajectory[\"steps\"], list):",
          "        raise KeyError(\"trajectory['steps'] missing or not a list\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    substeps = step.get(\"substeps\", [])",
          "    if not isinstance(substeps, list):",
          "        raise TypeError(\"step['substeps'] must be a list\")",
          "    assistant_substeps = [s for s in substeps if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps at current step; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Current assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    order_action_tools = [",
          "        \"get_order_details\",",
          "        \"cancel_pending_order\",",
          "        \"exchange_delivered_order_items\",",
          "        \"modify_pending_order_address\",",
          "        \"modify_pending_order_items\",",
          "        \"modify_pending_order_payment\",",
          "        \"return_delivered_order_items\"",
          "    ]",
          "    tool_present = any(re.search(r\"\\b\" + re.escape(t) + r\"\\b\", content) for t in order_action_tools)",
          "    print(\"Tool present triggering auth check:\", tool_present)",
          "    if not tool_present:",
          "        return True",
          "    # Scan earlier steps for authentication calls",
          "    auth_tools = [\"find_user_id_by_email\", \"find_user_id_by_name_zip\"]",
          "    found_auth = False",
          "    for i in range(0, current_step_index):",
          "        prev_step = trajectory[\"steps\"][i]",
          "        for ss in prev_step.get(\"substeps\", []):",
          "            if ss.get(\"role\") == \"assistant\":",
          "                c = ss.get(\"content\", \"\") or \"\"",
          "                if any(re.search(r\"\\b\" + re.escape(t) + r\"\\b\", c) for t in auth_tools):",
          "                    found_auth = True",
          "                    print(\"Found prior authentication call at step\", i+1)",
          "                    break",
          "        if found_auth:",
          "            break",
          "    print(\"Found_auth:\", found_auth)",
          "    if not found_auth:",
          "        print(\"Violation: Order actions attempted without prior authentication.\")",
          "        return False",
          "    return True"
        ]
      },
      "nl_check": {}
    },
