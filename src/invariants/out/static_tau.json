          "    \"\"Return True iff assistant tool call content is parseable JSON with expected structure.\"\"",
          "    print(\"tool_invocation_schema_parseable invoked\")",
          "    import json",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
          "    step = trajectory[\"steps\"][current_step_index]",
          "    assistant_substeps = [s for s in step.get(\"substeps\", []) if s.get(\"role\") == \"assistant\"]",
          "    if not assistant_substeps:",
          "        print(\"No assistant substeps; invariant not applicable.\")",
          "        return True",
          "    content = assistant_substeps[0].get(\"content\", \"\") or \"\"",
          "    print(\"Assistant content:\", (content[:200] + \"...\") if len(content) > 200 else content)",
          "    # Only check when content looks like a function call array",
          "    if \"\\\"type\\\"\" not in content or \"function\" not in content:",
          "        return True",
          "    try:",
