          "        \"list_all_product_types\",",
          "        \"get_order_details\",",
          "        \"get_product_details\",",
          "        \"get_user_details\",",
          "        \"cancel_pending_order\",",
          "        \"exchange_delivered_order_items\",",
          "        \"modify_pending_order_address\",",
          "        \"modify_pending_order_items\",",
          "        \"modify_pending_order_payment\",",
          "        \"modify_user_address\",",
          "        \"return_delivered_order_items\"",
          "    ]",
          "    if trajectory is None or \"steps\" not in trajectory:",
          "        raise KeyError(\"trajectory['steps'] missing\")",
          "    if current_step_index < 0 or current_step_index >= len(trajectory[\"steps\"]):",
          "        raise IndexError(\"current_step_index out of range\")",
